# ── Database ──────────────────────────────────────────
DATABASE_URL="mongodb://localhost:27017/telesync"

# ── GHL Marketplace App ──────────────────────────────
GHL_CLIENT_ID="your-ghl-client-id"
GHL_CLIENT_SECRET="your-ghl-client-secret"
GHL_REDIRECT_URI="https://your-server.com/auth/callback"
GHL_SSO_KEY="your-shared-secret-from-marketplace-dashboard"
GHL_APP_ID="your-marketplace-app-id"
GHL_CONVERSATION_PROVIDER_ID="your-conversation-provider-id"

# ── Encryption ───────────────────────────────────────
ENCRYPTION_KEY="32-byte-hex-string-for-aes-256-gcm"

# ── Server ───────────────────────────────────────────
PORT=3000
NODE_ENV="development"
BACKEND_URL="https://your-server.com"
FRONTEND_URL="https://your-frontend.com"

# ── GHL API Base ─────────────────────────────────────
GHL_API_BASE="https://services.leadconnectorhq.com"
GHL_API_VERSION="2021-04-15"

# ── Billing ──────────────────────────────────────────
# Internal testing company IDs are stored in MongoDB AppConfig collection
# (key: "internalTestingCompanyIds") — no env var needed.

# Meter IDs (from GHL marketplace billing config)
METER_ID_INBOUND=""
METER_ID_OUTBOUND=""
METER_ID_SEND_FILE_GROUP=""
METER_ID_INVITE_LINK=""
METER_ID_EDIT_GROUP_PERMS=""
METER_ID_SEND_MSG_USER=""
METER_ID_SEND_MSG_GROUP=""

# ── Telegram MTProto (Phone Number Login) ─────────
TELEGRAM_API_ID="your-api-id-from-my-telegram-org"
TELEGRAM_API_HASH="your-api-hash-from-my-telegram-org"
